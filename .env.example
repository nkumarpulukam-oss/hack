# ── Application ─────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=green_skills
DB_USER=postgres
DB_PASS=change_me_in_production
DB_SSL=false

# ── Auth / JWT ────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_prod

# ── SSO (Azure AD) ────────────────────────────────────
# Set these to enable real SSO. Leave empty to use demo login.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:4000/api/auth/callback

# ── LLM (Ollama local) ────────────────────────────────
# Start Ollama: ollama serve && ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
